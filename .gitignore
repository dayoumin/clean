# .gitignore 파일 내용

# .env 파일 무시 (API 키 노출 방지)
.env

# 로그 파일 무시
*.log

# 모든 .py 파일 무시
*.py
*.md
*.txt

# app_streamlit_cloud.py는 예외로 포함
!app_streamlit_cloud.py
!requirements.txt


# __pycache__ 폴더 무시 (Python 캐시 파일)
__pycache__/

# Streamlit Cloud와 상관없는 데이터 폴더 무시
data/

# 기타 필요 없는 시스템 파일 무시
.DS_Store

# Chroma 벡터스토어 잠금 파일 무시
chroma_vectorstore/*.lock
